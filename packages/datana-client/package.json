{
  "name": "@sawala/datana-client",
  "version": "0.2.0",
  "description": "TypeScript client for the Datana public read API — Sawala Cloud's structured-data platform. Framework-agnostic, runs in Node, browsers, and Cloudflare Workers.",
  "keywords": [
    "sawala",
    "sawala-tech",
    "sawala-cloud",
    "datana",
    "structured-data",
    "headless",
    "typescript"
  ],
  "license": "MIT",
  "author": "Sawala Cloud <hello@sawala.co> (https://sawala.co)",
  "homepage": "https://github.com/sawala-tech/sdk-typescript/tree/main/packages/datana-client",
  "repository": {
    "type": "git",
    "url": "https://github.com/sawala-tech/sdk-typescript.git",
    "directory": "packages/datana-client"
  },
  "bugs": "https://github.com/sawala-tech/sdk-typescript/issues",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  }
}
